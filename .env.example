ENV=local

JWT_SECRET=change-me
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30

DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/veradoc

REDIS_URL=redis://localhost:6379/0

FRONTEND_URL=http://localhost:3000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Email — pick one driver: resend (default) or smtp (Gmail, etc.)
EMAIL_DRIVER=resend

# Option A: Resend — https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key
# Sandbox onboarding@resend.dev only delivers to YOUR Resend signup email.
# Production: verify a domain at resend.com/domains → VeraDoc <noreply@yourdomain.com>
RESEND_FROM=VeraDoc <onboarding@resend.dev>

# Option B: Gmail SMTP (use an App Password, not your normal password)
# https://myaccount.google.com/apppasswords
# EMAIL_DRIVER=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-16-char-app-password
# SMTP_FROM=VeraDoc <you@gmail.com>
# SMTP_TLS=true

# Log OTP in server logs / API when ENV=local (set ENV=production in production)
OTP_LOG_CODES=

SQUAD_BASE_URL=https://sandbox-api-d.squadco.com
SQUAD_SECRET_KEY=
SQUAD_CURRENCY=NGN
SQUAD_CALLBACK_URL=http://localhost:3000/credits/callback

GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

FILE_STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=./storage
